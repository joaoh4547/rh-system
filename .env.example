# =====================================================================
# RH System — variáveis de ambiente da stack Docker
# Template versionável: copie para `.env` e preencha os valores.
#   cp .env.example .env
# (O `.env` real está no .gitignore — não commitar segredos.)
# =====================================================================

# ----- Banco de dados (PostgreSQL) -----
# Host do banco visto pelas instâncias (nome do serviço no compose)
DB_HOST=postgres
# Porta interna do Postgres na rede do compose
DB_PORT=5432
# Porta do Postgres exposta no host (para acesso com DBeaver/psql etc.)
DB_PORT_HOST=5432
DB_NAME=rh_system
DB_USER=postgres
DB_PASSWORD=troque-esta-senha

# ----- Email (SMTP Gmail — use uma "Senha de app" do Google) -----
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_FROM=no-reply@rhsystem.com

# ----- Aplicação -----
# URL pública (load balancer) — usada nos links de ativação por email
APP_BASE_URL=http://localhost:8080
# Validade do token de ativação (horas)
ATIVACAO_TOKEN_HORAS=24
# Diretório de anexos dentro dos containers (volume compartilhado app_storage)
STORAGE_DIR=/app/storage

# ----- Cache distribuído (Hazelcast) -----
# Instâncias com o mesmo nome de cluster compartilham o cache
HZ_CLUSTER_NAME=rh-system
# Descoberta TCP-IP entre as instâncias (nomes dos serviços no compose)
HZ_MEMBERS=app1:5701,app2:5701
HZ_PORT=5701
CACHE_TTL_SECONDS=600

# ----- Load balancer -----
# Porta do nginx exposta no host
LB_PORT=8080
